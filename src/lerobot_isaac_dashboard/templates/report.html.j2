<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>lerobot-isaac report — {{ run_id }}</title>
  {% if plotlyjs_tag %}{{ plotlyjs_tag | safe }}{% endif %}
  <style>
    /* Reset & base */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 14px;
      color: #1a1a2e;
      background: #f8f9fb;
      line-height: 1.55;
    }

    /* Hero banner */
    .hero {
      background: linear-gradient(135deg, #0f3460 0%, #16213e 100%);
      color: #e8eaf6;
      padding: 28px 40px 22px;
    }
    .hero h1 {
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      margin-bottom: 10px;
    }
    .hero-meta {
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 0.78rem;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 6px;
      padding: 10px 14px;
      display: inline-block;
      line-height: 1.8;
    }
    .hero-meta span { color: #90caf9; }

    /* Sticky nav */
    nav.tab-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #1a237e;
      padding: 0 40px;
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      box-shadow: 0 2px 8px rgba(0,0,0,0.25);
    }
    nav.tab-nav a {
      color: #c5cae9;
      text-decoration: none;
      padding: 10px 16px;
      font-size: 0.8rem;
      font-weight: 500;
      border-bottom: 3px solid transparent;
      transition: color 0.15s, border-color 0.15s;
      white-space: nowrap;
    }
    nav.tab-nav a:hover {
      color: #fff;
      border-bottom-color: #42a5f5;
    }

    /* Main content */
    main {
      max-width: 1400px;
      margin: 0 auto;
      padding: 32px 40px 64px;
    }

    /* Tab sections */
    section {
      margin-bottom: 56px;
      scroll-margin-top: 46px;
    }
    section h2 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #0f3460;
      border-left: 4px solid #1565c0;
      padding-left: 12px;
      margin-bottom: 16px;
    }

    /* Warning box */
    .warn {
      background: #fff8e1;
      border: 1px solid #ffe082;
      border-radius: 6px;
      padding: 10px 14px;
      margin-bottom: 14px;
      font-size: 0.82rem;
      color: #5d4037;
    }
    .warn ul { padding-left: 18px; }

    /* Empty state */
    .empty-state {
      color: #78909c;
      font-style: italic;
      padding: 16px 0;
    }

    /* Plotly figures auto-width */
    .plotly-graph-div { width: 100% !important; }

    /* Footer */
    footer {
      text-align: center;
      font-size: 0.75rem;
      color: #90a4ae;
      padding: 24px;
      border-top: 1px solid #e0e0e0;
    }

    @media (max-width: 700px) {
      .hero, main { padding-left: 16px; padding-right: 16px; }
      nav.tab-nav { padding: 0 8px; }
      nav.tab-nav a { padding: 8px 10px; font-size: 0.72rem; }
    }
  </style>
</head>
<body>

<div class="hero">
  <h1>lerobot-isaac metrics report</h1>
  <div class="hero-meta">
    <span>run_id</span>       {{ run_id }}<br>
    <span>workspace</span>    {{ workspace_root }}<br>
    <span>session_id</span>   {{ session_id if session_id else "(none)" }}<br>
    <span>generated_at</span> {{ generated_at }}
  </div>
</div>

<nav class="tab-nav">
  {% for tab in tabs %}
  <a href="#{{ tab.slug }}">{{ tab.title }}</a>
  {% endfor %}
</nav>

<main>
  {% for tab in tabs %}
  {% include "tab.html.j2" %}
  {% endfor %}
</main>

<footer>
  Generated by lerobot-isaac-dashboard &mdash; {{ generated_at }}
</footer>

</body>
</html>
